# .env.example

# ── NVIDIA LLM (Language Model – Brain) ──────────────────────────────────────
NVIDIA_API_KEY=nvapi-your_nvidia_api_key_here
NVIDIA_LLM_MODEL=meta/llama-3.1-8b-instruct

# ── ElevenLabs TTS (Optional – better voice quality) ─────────────────────────
ELEVENLABS_API_KEY=sk_your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL=eleven_monolingual_v1

# ── JARVIS Core Settings ──────────────────────────────────────────────────────
WAKE_WORD=jarvis
VOICE_ENABLED=true
MEMORY_FILE=jarvis_memory.json
MAX_HISTORY=10

# ── MCP Tool Server ───────────────────────────────────────────────────────────
# Set to true to expose tools over HTTP/SSE on the port below.
MCP_SERVER_ENABLED=false
MCP_SERVER_HOST=127.0.0.1
MCP_SERVER_PORT=8765

# When true, tools marked as destructive require explicit user confirmation.
APPROVAL_MODE=false

# Maximum number of tool-calling rounds per user request.
MAX_TOOL_ITERATIONS=5

# Maximum seconds a single tool call may run.
TOOL_TIMEOUT=30

# ── Web API Keys (free tiers) ─────────────────────────────────────────────────
# OpenWeatherMap free tier – https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweathermap_api_key_here

# ── Knowledge Base ────────────────────────────────────────────────────────────
KNOWLEDGE_STORE_FILE=jarvis_knowledge.json

# ── Home Automation (optional) ────────────────────────────────────────────────
# Base URL of your smart-home hub, e.g. http://homeassistant.local:8123
HOME_AUTOMATION_URL=